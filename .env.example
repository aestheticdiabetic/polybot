# ─── PolyBot Environment Variables ───────────────────────────────
# Copy this to .env and fill in your values.
# NEVER commit .env to git.

# ── Polygon wallet (your trading wallet private key)
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# ── Polymarket proxy wallet address (shown at polymarket.com/settings)
FUNDER_ADDRESS=0xYOUR_POLYMARKET_PROXY_WALLET

# ── Polymarket CLOB API credentials
# Generate these at: polymarket.com/settings → API Keys
POLY_API_KEY=your-api-key
POLY_API_SECRET=your-api-secret
POLY_API_PASSPHRASE=your-api-passphrase

# ── Alchemy (Polygon mainnet)
# Create a Polygon Mainnet app at dashboard.alchemy.com
ALCHEMY_API_KEY=your-alchemy-api-key

# ── Dashboard
# Password to access the web dashboard (use SSH tunnel, see README)
DASHBOARD_SECRET=change_this_to_something_strong
DASHBOARD_PORT=8080

# ── Bot behaviour
# Set to "true" to start trading automatically on container start
# Leave "false" to control via dashboard
AUTO_START=false

# ── Logging
LOG_LEVEL=INFO
